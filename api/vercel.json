{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "GOOGLE_SHEETS_ID": "@google_sheets_id",
    "GOOGLE_SERVICE_ACCOUNT_KEY": "@google_service_account_key"
  }
}
